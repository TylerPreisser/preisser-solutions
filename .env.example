# Google Analytics 4
# Set this to your GA4 measurement ID to enable analytics tracking.
# Example: G-XXXXXXXXXX
# Set in Cloudflare Pages environment variables or .env.local (never commit .env.local).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console HTML tag verification
# Paste the token value only (the content attribute of the meta tag GSC gives you).
# Example: abc123def456...
# Leave unset if verifying via DNS TXT record instead.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=<paste-google-verification-token-here>

# Bing Webmaster Tools verification (also feeds ChatGPT/Bing AI)
# Paste the content value from the meta tag Bing Webmaster Tools gives you.
# Example: ABCDEF1234567890...
# Leave unset if not using Bing Webmaster Tools.
NEXT_PUBLIC_BING_SITE_VERIFICATION=<paste-bing-verification-token-here>

{
  "$schema": "https://static.modelcontextprotocol.io/schemas/mcp-server-card/v1.json",
  "protocolVersion": "2025-06-18",
  "serverInfo": {
    "name": "Preisser Tech Agent Discovery",
    "version": "1.0.0"
  },
  "description": "Discovery endpoint for Preisser Tech services, agent-readable site context, and structured inquiry handoffs.",
  "transport": {
    "type": "streamable-http",
    "url": "https://preissertech.com/mcp"
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "resources": {
      "subscribe": false,
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "preisser_tech_start_inquiry",
      "description": "Create a structured inquiry handoff for a custom website, web app, automation, dashboard, integration, or AI agent project.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "company": { "type": "string" },
          "projectType": { "type": "string" },
          "message": { "type": "string" }
        },
        "required": ["message"],
        "additionalProperties": false
      }
    }
  ],
  "documentation": "https://preissertech.com/docs/agent-api.md",
  "skills": "https://preissertech.com/.well-known/agent-skills/index.json"
}

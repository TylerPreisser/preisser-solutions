{
  "$schema": "https://static.modelcontextprotocol.io/schemas/mcp-server-card/v1.json",
  "protocolVersion": "2025-06-18",
  "serverInfo": {
    "name": "Preisser Solutions Agent Discovery",
    "version": "1.0.0"
  },
  "description": "Discovery endpoint for Preisser Solutions Hays local marketing services, agent-readable site context, and structured inquiry handoffs.",
  "transport": {
    "type": "streamable-http",
    "url": "https://preissersolutions.com/mcp"
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "resources": {
      "subscribe": false,
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "preisser_solutions_start_inquiry",
      "description": "Create a structured inquiry handoff for Hays Visibility Audit, local SEO, Google Business Profile, Google Ads, web design, review, lead tracking, social media marketing, or AI automation work.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "company": { "type": "string" },
          "projectType": { "type": "string" },
          "message": { "type": "string" }
        },
        "required": ["message"],
        "additionalProperties": false
      }
    }
  ],
  "documentation": "https://preissersolutions.com/docs/agent-api.md",
  "skills": "https://preissersolutions.com/.well-known/agent-skills/index.json"
}
